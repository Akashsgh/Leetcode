import java.util.*;

class Solution {
    public int jump(int[] nums) {
        int n = nums.length;
        Queue<Integer> q = new LinkedList<>();
        boolean[] visited = new boolean[n];
        q.offer(0);
        visited[0] = true;
        int jumps = 0;
        while (!q.isEmpty()) {
            int size = q.size();
            for (int i = 0; i < size; i++) {
                int index = q.poll();
                if (index == n - 1)
                    return jumps;

                for (int step = 1; step <= nums[index]; step++) {

                    int next = index + step;

                    if (next < n && !visited[next]) {
                        visited[next] = true;
                        q.offer(next);
                    }
                }
            }

            jumps++;
        }

        return -1;
    }
}
