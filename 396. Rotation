class Solution {
    public int maxRotateFunction(int[] nums) {
        int n = nums.length;
        int sum = 0;
        int S = 0;

        for (int i = 0; i < n; i++) {
            sum += nums[i];
            S += i * nums[i];
        }

        int max = S;

        
        for (int k = 1; k < n; k++) {
            S = S + sum - n * nums[n - k];
            max = Math.max(max, S);
        }

        return max;
    }
}
