class Solution {
    public boolean rotateString(String s, String goal) {
        if (s.length() != goal.length()) return false;

        char[] arr = s.toCharArray();
        int n = arr.length;

        for (int k = 0; k < n; k++) {

            char first = arr[0];

            for (int i = 0; i < n - 1; i++) {
                arr[i] = arr[i + 1];
            }

            arr[n - 1] = first;

            if (new String(arr).equals(goal)) return true;
        }

        return false;
    }
}
